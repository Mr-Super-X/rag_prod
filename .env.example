# RAG 知识库平台 — 环境变量配置
# 复制此文件为 .env 并修改配置

# ===== 数据库 =====
DATABASE_URL=postgresql://raguser:ragpass@localhost:5432/ragdb

# ===== Ollama（本地 LLM）=====
OLLAMA_URL=http://localhost:11434

# ===== Redis（BM25 索引 + 缓存）=====
REDIS_URL=redis://localhost:6379

# ===== JWT 认证 =====
# 生产环境务必改为随机长字符串
JWT_SECRET=change-me-to-a-random-secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ===== 文件上传 =====
UPLOAD_DIR=./data/uploads
MAX_FILE_SIZE_MB=50

# ===== LLM 模型配置 =====
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:7b
# LLM_PROVIDER=deepseek 时需要：
# DEEPSEEK_API_KEY=sk-xxxxxxxx
# DEEPSEEK_MODEL=deepseek-chat

# ===== Embedding 模型配置 =====
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIM=1024

# ===== 文档切分配置 =====
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ===== 检索配置 =====
RETRIEVAL_TOP_K=25
FINAL_TOP_K=10
RRF_K=60
SIMILARITY_THRESHOLD=0.5

# ===== Reranker（精排）=====
# 开启后检索结果用 LLM 精排，更准但更慢
RERANKER_ENABLED=false
RERANKER_TOP_K=25

# ===== 增量索引 =====
# 开启后文档重上传只处理变化的部分
INCREMENTAL_INDEX=false

# ===== Agent 功能 =====
# 开启后支持时间查询、计算器等非文档类问题
AGENT_ENABLED=false

# ===== 日志 =====
LOG_LEVEL=info
